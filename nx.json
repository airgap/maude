{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": ["{projectRoot}/**/*"],
    "production": ["default", "!{projectRoot}/**/__tests__/**", "!{projectRoot}/**/*.test.*"]
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["production"],
      "cache": true
    },
    "check": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "test": {
      "inputs": ["default"],
      "cache": true
    }
  },
  "defaultBase": "main"
}
